# --- Required ---------------------------------------------------------------
# Personal Access Token (classic or fine-grained) with at least:
#   - repo:read for private repos (or "public_repo" for public-only)
#   - issues:write to create issues / post comments
# Create one at https://github.com/settings/tokens
GITHUB_TOKEN=

# --- Optional defaults ------------------------------------------------------
# When tools are called without owner/repo arguments, these are used.
# Leave blank to require callers to always pass owner/repo explicitly.
DEFAULT_GITHUB_OWNER=
DEFAULT_GITHUB_REPO=
